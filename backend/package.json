{
  "name": "zalohub-backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "tsx src/core/index.ts",
    "server:dev": "tsx src/server/index.ts",
    "admin:dev": "vite src/admin --config src/admin/vite.config.ts",
    "admin:build": "vite build src/admin --config src/admin/vite.config.ts",
    "build": "tsc && npm run admin:build",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "dev": "npm run server:dev"
  },
  "dependencies": {
    "express": "^4.21.2",
    "jpeg-js": "^0.4.4",
    "jsqr": "^1.4.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "minio": "^8.0.5",
    "multer": "^2.1.1",
    "pg": "^8.14.1",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "zalo-api-final": "^2.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.12"
  }
}
