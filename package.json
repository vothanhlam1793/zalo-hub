{
  "name": "mychat-zalo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:chat dev:zalo",
    "dev:chat": "tsx watch src/chat-server/index.ts",
    "dev:zalo": "tsx watch src/zalo-service/index.ts",
    "gold:cli": "tsx src/gold-1/index.ts",
    "gold:menu": "tsx src/gold-1/index.ts menu",
    "gold:login": "tsx src/gold-1/index.ts login",
    "gold:friends": "tsx src/gold-1/index.ts friends",
    "gold:doctor": "tsx src/gold-1/index.ts doctor",
    "gold:send": "tsx src/gold-1/index.ts send",
    "gold4:web": "vite src/gold-4-web --config src/gold-4-web/vite.config.ts",
    "gold4:build": "vite build src/gold-4-web --config src/gold-4-web/vite.config.ts",
    "gold2:web": "tsx src/gold-2/server.ts",
    "build": "tsc",
    "start": "./start.sh",
    "start:win": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "stop:win": "powershell -ExecutionPolicy Bypass -File ./stop.ps1",
    "restart:win": "powershell -ExecutionPolicy Bypass -File ./restart.ps1",
    "start:chat": "node dist/chat-server/index.js",
    "start:zalo": "node dist/zalo-service/index.js"
  },
  "dependencies": {
    "@chatscope/chat-ui-kit-react": "^2.1.1",
    "@chatscope/chat-ui-kit-styles": "^1.4.0",
    "@types/multer": "^2.1.0",
    "express": "^4.21.2",
    "jsqr": "^1.4.0",
    "multer": "^2.1.1",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.18.0",
    "zalo-api-final": "^2.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^24.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.12"
  }
}
